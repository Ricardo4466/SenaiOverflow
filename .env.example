PORT=3333
NODE_ENV=development

JWT_SECRET=altere-em-producao
SKIP_FIREBASE=true

# Login com Google (mesmo REACT_APP_GOOGLE_CLIENT_ID do front)
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Postgres em cloud (Render, Railway, Neon): costuma usar DATABASE_URL + SSL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=true

# Opção local: variáveis separadas
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=senai_overflow

# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
